import { Button, VerticalBox, HorizontalBox } from "std-widgets.slint";
import { AppState, EntryRow, FilePreviewRow } from "state.slint";
import { WizardPane } from "wizard.slint";
import { EnrollmentPane } from "enrollment.slint";

// Re-export so `slint::include_modules!()` exposes AppState (the
// global) and the FilePreviewRow struct to Rust. Without this,
// `ui.global::<AppState>()` fails to compile because the Rust type
// isn't generated — Slint only emits bindings for items the main
// file directly uses or re-exports.
export { AppState, FilePreviewRow }

// Top-level window. Switches on `AppState.mode` between the four
// pane families. Wizard and Enrollment are heavy enough to live in
// their own files (`wizard.slint`, `enrollment.slint`); locked +
// code-panel are short enough to stay inline here.
export component MainWindow inherits Window {
    title: "tocken";
    preferred-width: 480px;
    preferred-height: 580px;
    background: #111;

    VerticalBox {
        padding: 24px;
        spacing: 14px;

        if AppState.mode == 0: Text {
            text: "tocken first-run setup";
            font-size: 12px;
            color: #777;
            horizontal-alignment: center;
        }

        if AppState.mode == 0: WizardPane {}

        // ---------- mode 1 / locked ----------

        if AppState.mode == 1: VerticalBox {
            spacing: 14px;
            alignment: center;
            Text {
                text: "tocken";
                font-size: 28px;
                color: #f0f0f0;
                horizontal-alignment: center;
            }
            Text {
                text: AppState.unlocking ? "Touch your YubiKey when it blinks…" : "Touch your YubiKey to unlock.";
                font-size: 13px;
                color: #b0b0b0;
                wrap: word-wrap;
                horizontal-alignment: center;
            }
            if AppState.unlock-error != "": Text {
                text: AppState.unlock-error;
                color: #ff8080;
                font-size: 12px;
                wrap: word-wrap;
                horizontal-alignment: center;
            }
            Rectangle { height: 8px; }
            Button {
                text: AppState.unlocking ? "Awaiting touch…" : "Unlock";
                primary: true;
                enabled: !AppState.unlocking;
                clicked => {
                    AppState.unlock-error = "";
                    AppState.unlock();
                }
            }
        }

        // ---------- mode 2 / unlocked code panel ----------

        if AppState.mode == 2: VerticalBox {
            spacing: 8px;

            HorizontalBox {
                spacing: 8px;
                Text {
                    text: "tocken";
                    font-size: 14px;
                    color: #888;
                    vertical-alignment: center;
                }
                Rectangle { horizontal-stretch: 1; }
                Text {
                    text: AppState.entries.length == 0 ? "" : ("re-lock " + AppState.relock-seconds + "s");
                    font-size: 11px;
                    color: #555;
                    vertical-alignment: center;
                }
            }

            if AppState.entries.length == 0: VerticalBox {
                spacing: 6px;
                alignment: center;
                Rectangle { height: 40px; }
                Text {
                    text: "No entries yet.";
                    font-size: 16px;
                    color: #b0b0b0;
                    horizontal-alignment: center;
                }
                Text {
                    text: "Click + Add to enroll your first TOTP.";
                    font-size: 11px;
                    color: #555;
                    horizontal-alignment: center;
                }
            }

            for entry in AppState.entries: VerticalBox {
                spacing: 4px;
                padding-top: 6px;
                padding-bottom: 6px;
                HorizontalBox {
                    spacing: 12px;
                    VerticalBox {
                        spacing: 0px;
                        Text {
                            text: entry.issuer;
                            color: #f0f0f0;
                            font-size: 13px;
                        }
                        Text {
                            text: entry.account;
                            color: #888;
                            font-size: 10px;
                        }
                    }
                    Rectangle { horizontal-stretch: 1; }
                    VerticalBox {
                        spacing: 0px;
                        alignment: center;
                        Text {
                            text: entry.code;
                            color: #d0e8ff;
                            font-size: 22px;
                            horizontal-alignment: right;
                        }
                        Text {
                            text: entry.digits + "d / " + entry.period + "s";
                            color: #555;
                            font-size: 9px;
                            horizontal-alignment: right;
                        }
                    }
                }
                Rectangle {
                    height: 3px;
                    background: #1a1a1a;
                    border-radius: 1.5px;
                    Rectangle {
                        x: 0;
                        y: 0;
                        height: 3px;
                        background: #4a90e2;
                        width: parent.width * entry.time-remaining / max(entry.period, 1);
                        border-radius: 1.5px;
                    }
                }
            }

            Rectangle { vertical-stretch: 1; }

            HorizontalBox {
                spacing: 12px;
                Button {
                    text: "+ Add";
                    clicked => { AppState.open-enroll(); }
                }
                Rectangle { horizontal-stretch: 1; }
                Button {
                    text: "Lock";
                    clicked => { AppState.lock(); }
                }
            }
        }

        // ---------- mode 3 / enrollment ----------

        if AppState.mode == 3: EnrollmentPane {}
    }
}
