// Shared types + global app state.
//
// Slint `global` is the idiomatic way to share mutable state across
// composed components without per-property pass-through bindings.
// Every pane (wizard, locked, code, enrollment) reads and writes
// `AppState`; the Rust side uses `ui.global::<AppState>()` for the
// same getters / setters / callback wiring it would otherwise call
// on the window.
//
// Anything that's truly just a render-local detail (transient
// animation state, focus tracking) can stay on its own component;
// state that crosses panes belongs here.

// One row of the unlocked code panel. Mirrors
// `tocken_core::session::EntryCode` after stringification; see
// `tick_codes` in src/main.rs. `selected` is set from the Rust-side
// selection set (in `Unlocked`) so it survives the 1Hz tick that
// rebuilds the model.
export struct EntryRow {
    id: string,
    issuer: string,
    account: string,
    code: string,
    digits: int,
    period: int,
    time-remaining: int,
    selected: bool,
}

// One decoded payload from a file-picker import. Mirrors
// `tocken_core::enroll::file::FileRowPreview` flattened for Slint:
// either `error` is non-empty (parse / validate failure for that
// row) OR issuer/account/payload are populated. `selected` drives
// the per-row checkbox; the Rust toggle handler flips it via
// `Model::set_row_data`. Default selection: valid rows in, weak
// rows out (explicit opt-in), error rows can't be selected at all.
export struct FilePreviewRow {
    issuer: string,
    account: string,
    weak-bits: int,
    error: string,
    payload: string,
    selected: bool,
}

export global AppState {
    // App-wide mode: 0=wizard, 1=locked, 2=unlocked, 3=enrollment.
    in-out property <int> mode: 0;

    // Wizard sub-step (only consulted when mode == 0).
    // 0=welcome, 1=passphrase, 2=confirm, 3=yubikey, 4=location, 5=done.
    in-out property <int> step: 0;

    // ---- wizard: passphrase pane ----
    in-out property <string> passphrase: "";
    in-out property <string> passphrase-confirm: "";
    in-out property <bool> confirm-error: false;
    in-out property <bool> passphrase-copied: false;

    // ---- wizard: yubikey pane ----
    in-out property <bool> yubikey-detected: false;
    in-out property <bool> yubikey-configured: false;
    in-out property <string> yubikey-recipient: "";
    in-out property <string> yubikey-serial: "";
    in-out property <string> yubikey-error: "";
    in-out property <bool> provision-in-progress: false;
    in-out property <string> provision-log: "";
    in-out property <string> pin-puk-message: "";

    // ---- wizard: location / finalize ----
    in-out property <string> store-path: "";
    in-out property <string> master-path: "";
    in-out property <string> config-path: "";
    in-out property <bool> finalize-in-progress: false;
    in-out property <string> finalize-error: "";

    // ---- locked pane (mode = 1) ----
    in-out property <bool> unlocking: false;
    in-out property <string> unlock-error: "";

    // ---- code panel (mode = 2) ----
    in-out property <[EntryRow]> entries: [];
    in-out property <int> relock-seconds: 0;
    // Actions mode: when true, per-row checkboxes appear and the
    // bottom action bar swaps to [Done | Remove | Update | Comment].
    // Selection state lives in Rust (`Unlocked.selected_ids`) so
    // each tick can reconstruct `EntryRow.selected` from it.
    in-out property <bool> actions-active: false;
    in-out property <int> selected-count: 0;
    // Remove confirmation sub-state — flips to true between the
    // user clicking Remove and confirming. Occludes the code panel
    // with a "won't be recoverable" warning.
    in-out property <bool> confirming-remove: false;
    // Transient one-line status banner (e.g. "Coming next session"
    // for unimplemented Update / Comment). Empty hides it.
    in-out property <string> action-toast: "";

    // ---- enrollment (mode = 3) ----
    in-out property <int> enroll-source: 0;        // 0=paste, 1=manual, 2=file, 3=clipboard, 4=camera
    in-out property <string> enroll-uri: "";
    in-out property <string> enroll-issuer: "";
    in-out property <string> enroll-account: "";
    in-out property <string> enroll-secret: "";
    in-out property <string> enroll-digits: "6";
    in-out property <string> enroll-period: "30";
    in-out property <string> enroll-error: "";
    in-out property <bool> enroll-weak-prompt: false;
    in-out property <int> enroll-weak-bits: 0;
    in-out property <bool> enroll-saving: false;
    // file + clipboard image sources both populate enroll-file-rows
    // (same row shape; same Save pipeline). source-path is non-empty
    // only for the file picker, which is what gates destroy-source.
    in-out property <string> enroll-file-path: "";
    in-out property <bool> enroll-file-loading: false;
    in-out property <bool> enroll-clipboard-loading: false;
    in-out property <[FilePreviewRow]> enroll-file-rows: [];
    in-out property <int> enroll-file-valid: 0;
    in-out property <int> enroll-file-weak: 0;
    in-out property <int> enroll-file-error: 0;
    // Optional: zero-fill + unlink the source file after a successful
    // batch import. Off by default — destructive action. Best-effort
    // under modern filesystem realities (CoW, journals, SSD wear
    // leveling) per `enroll::file::destroy_file`.
    in-out property <bool> enroll-destroy-source: false;
    // Camera source: live preview frame + watch state. The frame is
    // pushed by the camera worker thread on each PipeWire process
    // callback (~30fps); status flips between hint text and "Got it."
    // The reticle is a UI-only overlay, not a Rust-side concept.
    in-out property <bool> enroll-camera-watching: false;
    in-out property <string> enroll-camera-status: "";
    in-out property <image> enroll-camera-frame;

    // ---- callbacks ----
    callback generate-passphrase();
    callback copy-passphrase();
    callback detect-yubikey();
    callback provision-yubikey();
    callback finalize();
    callback unlock();
    callback lock();
    callback open-enroll();
    callback cancel-enroll();
    callback save-enroll();
    callback save-enroll-force();
    callback choose-enroll-file();
    callback read-enroll-clipboard();
    callback start-camera-watch();
    callback stop-camera-watch();
    callback save-enroll-file();
    callback toggle-file-row(int);
    // Actions mode
    callback enter-actions();
    callback exit-actions();
    callback toggle-entry-selected(string);
    callback confirm-remove();
    callback show-coming-soon(string);
}
